rules_version = '2';

// ============================================================
// Sound Platform — Cloud Firestore Security Rules
// Project:  sound-platform-dev
// Region:   europe-west1
// Phase:    6-A (Profile + PublicProfile + Privacy schema foundation)
// Updated:  2026-05-25
//
// CHANGELOG (Phase 6-A):
//   - Added privacySettings/{uid} rule — owner read/write, no client delete.
//   - uid and createdAt are immutable fields in privacySettings.
//
// Previous Phase: 4-H-3 (Online Rules Deployed — 2026-05-14)
//
// PERMISSION MODEL (Phase 4-H-2 — Privacy Correction):
//
//   PROFILE PRIVACY:
//   - users/{uid}        → PRIVATE. Readable only by owner, admin, or server.
//                          Contains: settings, capabilities, restrictions,
//                          privacy config, internal flags, consumer activity.
//                          Raw document NEVER accessible to other users.
//   - publicProfiles/{uid} → PUBLIC PROJECTION. Readable by any auth user.
//                          Built section-by-section from users/{uid} by a
//                          Cloud Function, respecting privacy settings.
//                          Contains only what the owner has made visible.
//
//   PUBLIC PROFILE SECTIONS (all independently privacy-controlled):
//     - general profile (username, bio, avatar, counters)
//     - mood
//     - listening activity (latest listened item)
//     - followed radio stations
//     - followed radio station lists
//     - music playlists
//     - Plus creator content section
//     - Music creator content section
//     - Radio creator content section
//
//   VIEWING CONTENT:
//   - Plus is NOT a viewer gate. Published content in ANY world is readable
//     by any authenticated user. Read gates: published status, moderation.
//   - Privacy and block enforcement is done by Cloud Function projection.
//
//   CREATION / PUBLISHING:
//   - General world: open by default (restricted by bans/violations/admin action)
//   - General live: any user unless account is restricted
//   - Plus world publishing: requires plus_creator capability (CF check)
//   - Plus live: requires plus_creator capability
//   - Music uploading: requires music_creator capability
//   - Radio stations: requires radio_creator capability
//   All capability checks are enforced by Cloud Functions only.
//
//   RADIO SPECIFICS:
//   - Radio station has ownerProfileId + contact page/config
//   - Radio comments live inside the radio player collection
//   - Live broadcast messages route to the inbox of the station owner profile
//
// GENERAL STRATEGY:
//   - Default deny everything unless explicitly matched below.
//   - Sensitive collections (wallet, payment, payout, audit,
//     adminConfig, moderationQueue, kycDocuments, childGuardianLinks)
//     are SERVER-ONLY: no client read or write permitted.
//   - Cloud Functions enforce all writes to server-only collections
//     via the Admin SDK (bypasses these rules).
//   - Admin claims are set by Cloud Functions only, checked via
//     request.auth.token.role.
// ============================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------
    // HELPER FUNCTIONS
    // ----------------------------------------------------------

    // Is the request from a signed-in user?
    function isAuth() {
      return request.auth != null;
    }

    // Is the requester the owner of this document?
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Is the requester a platform admin or superAdmin?
    // Roles are set as custom claims by Cloud Functions (Admin SDK) only.
    // superAdmin and admin roles are the only roles that bypass data-layer
    // restrictions at the rules level; all other role checks (moderator,
    // creator, listener) are enforced in Cloud Functions, not rules.
    function isAdmin() {
      return isAuth() && (
        request.auth.token.get('role', '') == 'admin' ||
        request.auth.token.get('role', '') == 'superAdmin'
      );
    }

    // isPublished — checks published status on the incoming/existing document.
    function isPublished(data) {
      return data.get('status', '') == 'published';
    }

    // ----------------------------------------------------------
    // DEFAULT DENY — catch-all at the root level
    // Any collection not explicitly matched below is DENIED.
    // ----------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ----------------------------------------------------------
    // users/{uid}  — PRIVATE internal profile document
    //
    // Contains: settings, capabilities, restrictions, privacy config,
    // internal flags, consumer activity raw data.
    //
    // NEVER readable by other users via client SDK.
    // Other users access profile data ONLY through publicProfiles/{uid}.
    // Cloud Functions read this doc to build the public projection.
    // Children accounts: writes gated by guardian approval (CF only).
    // ----------------------------------------------------------
    match /users/{uid} {
      // Owner: full read of own private document.
      // Admin: full read (moderation, support).
      // ALL OTHER USERS: denied — must use publicProfiles/{uid} instead.
      allow read: if isOwner(uid) || isAdmin();

      // Owner can update own non-sensitive profile fields.
      // The following fields are permanently server-only:
      //   role, accountType, walletId, kycStatus, guardianUid, isMinor,
      //   bannedAt, suspendedAt, deletedAt, createdAt,
      //   capabilities, restrictions, isBanned
      allow update: if isOwner(uid)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['role', 'accountType', 'walletId', 'kycStatus',
                     'guardianUid', 'isMinor', 'bannedAt',
                     'suspendedAt', 'deletedAt', 'createdAt',
                     'capabilities', 'restrictions', 'isBanned']);
      allow create: if false; // Cloud Function (onUserCreate trigger) only
      allow delete: if false; // Cloud Function only
    }

    // ----------------------------------------------------------
    // publicProfiles/{uid}  — Public profile projection
    //
    // This collection holds section-based public projections built
    // by Cloud Functions from users/{uid}, respecting privacy settings.
    //
    // Each document contains only sections the owner has made visible.
    // Privacy-hidden sections are entirely absent (not null/empty).
    //
    // Sections (each independently privacy-controlled):
    //   - generalProfile   (username, bio, avatar, social counters)
    //   - mood             (current mood string)
    //   - listeningActivity (latest listened item)
    //   - followedRadioStations
    //   - followedRadioStationLists
    //   - musicPlaylists
    //   - plusCreatorContent (Plus world content list — visibility only)
    //   - musicCreatorContent (Music world content list)
    //   - radioCreatorContent (Radio stations/shows list)
    //
    // Read: any authenticated user.
    // Write: Cloud Function only (onUserUpdate, onPrivacyChange triggers).
    // ----------------------------------------------------------
    match /publicProfiles/{uid} {
      allow read: if isAuth();
      allow write: if false; // Cloud Function only — never client-writable
    }

    // ----------------------------------------------------------
    // privacySettings/{uid}  — AccountControlHub Privacy Center state
    //
    // Stores the user's 13 privacy group settings from the AccountControlHub
    // Privacy Center UI. Separate from users/{uid}.privacy which drives the
    // publicProfiles projection.
    //
    // Read:   owner only (private configuration — not shared with other users).
    // Write:  owner can create/update. Cloud Functions read to sync back to
    //         users/{uid}.privacy for publicProfiles projection.
    // Delete: not permitted from client — admin/CF only.
    //
    // Immutable fields:
    //   uid       — must match document owner and must not change.
    //   createdAt — set on creation, must not change on update.
    //
    // Phase 6-A: uid validation and createdAt immutability enforced.
    // Phase 7: Cloud Function trigger onPrivacySettingsUpdate will sync
    //   selected fields back to users/{uid}.privacy for projection rebuild.
    // ----------------------------------------------------------
    match /privacySettings/{uid} {
      // Owner can read own privacy settings
      allow read: if isOwner(uid);

      // Owner can create the document (fallback if onUserCreate missed it)
      // uid field must match the authenticated user
      allow create: if isOwner(uid)
        && request.resource.data.uid == uid;

      // Owner can update — uid and createdAt must not change
      allow update: if isOwner(uid)
        && request.resource.data.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['uid', 'createdAt']);

      // No client delete
      allow delete: if false;
    }

    // ----------------------------------------------------------
    // usernames/{username}
    // Username uniqueness registry.
    // Read: any authenticated user (for availability check).
    // Write: Cloud Function only (atomic with user creation).
    // ----------------------------------------------------------
    match /usernames/{username} {
      allow read: if isAuth();
      allow write: if false; // Cloud Function only
    }

    // ----------------------------------------------------------
    // channels/{channelId}
    // Creator channels / podcast channels / radio channels.
    // Published channels: readable by any authenticated user.
    // Owner: can update own channel metadata (non-sensitive).
    // Sensitive fields (monetizationStatus, verifiedAt, bannedAt)
    //   are server-only writes.
    // ----------------------------------------------------------
    match /channels/{channelId} {
      // Any authenticated user can read published channels.
      // World (General / Plus / Music / Radio) does NOT restrict reading.
      // Plus is NOT a viewer gate — only published status matters.
      allow read: if isAuth() && isPublished(resource.data);
      allow read: if isOwner(resource.data.ownerUid) || isAdmin();
      allow update: if isOwner(resource.data.ownerUid)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['monetizationStatus', 'verifiedAt', 'bannedAt',
                     'createdAt', 'ownerUid']);
      allow create: if false; // Cloud Function only (capability check enforced there)
      allow delete: if false; // Cloud Function only

      // Episodes / tracks subcollection
      match /episodes/{episodeId} {
        // Any authenticated user can read published episodes regardless of world.
        allow read: if isAuth() && isPublished(resource.data);
        allow read: if isOwner(resource.data.get('ownerUid', '')) || isAdmin();
        allow write: if false; // Cloud Function only
      }
    }

    // ----------------------------------------------------------
    // content/{contentId}
    // Shorts, long-form audio, clips, etc.
    // Same published-gate as channels/episodes.
    // ----------------------------------------------------------
    match /content/{contentId} {
      // Any authenticated user can read published content regardless of world.
      // Plus content, Music content, Radio content — all readable when published.
      // Privacy and block enforcement is done by Cloud Function projection.
      allow read: if isAuth() && isPublished(resource.data);
      allow read: if isOwner(resource.data.get('ownerUid', '')) || isAdmin();
      allow write: if false; // Cloud Function only (capability check enforced there)
    }

    // ----------------------------------------------------------
    // competitions/{competitionId}
    // Competition definitions and state.
    // Published: readable by all authenticated users.
    // Jury scoring and winner writes: Cloud Function only.
    // ----------------------------------------------------------
    match /competitions/{competitionId} {
      allow read: if isAuth() && isPublished(resource.data);
      allow read: if isAdmin();
      allow write: if false; // Cloud Function only

      // Entries subcollection
      match /entries/{entryId} {
        allow read: if isAuth() && isPublished(resource.data);
        // Entry submission: Cloud Function validates eligibility
        allow write: if false; // Cloud Function only
      }

      // Scores: server-only
      match /scores/{scoreId} {
        allow read, write: if false; // Cloud Function / jury system only
      }
    }

    // ----------------------------------------------------------
    // sessions/{sessionId}
    // Live sessions (audio/voice room).
    // Active sessions: readable by authenticated users.
    // Lifecycle (create/end/archive): Cloud Function only.
    // ----------------------------------------------------------
    // ----------------------------------------------------------
    // liveSessions/{sessionId}
    // Live session metadata (General or Plus world).
    // Any authenticated user can view any live session — world does NOT
    // restrict reading. Plus live merely requires plus_creator capability
    // to HOST (enforced by Cloud Function), not to VIEW.
    // ----------------------------------------------------------
    match /liveSessions/{sessionId} {
      allow read: if isAuth();
      allow write: if false; // Cloud Function only (capability check enforced there)
    }

    // Legacy alias (keep for backward compat during transition)
    match /sessions/{sessionId} {
      allow read: if isAuth();
      allow write: if false; // Cloud Function only
    }

    // ----------------------------------------------------------
    // notifications/{uid}/items/{notificationId}
    // User notification inbox.
    // Owner can read own notifications and mark as read.
    // Write/create: Cloud Function only.
    // ----------------------------------------------------------
    match /notifications/{uid}/items/{notificationId} {
      allow read: if isOwner(uid);
      allow update: if isOwner(uid)
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['readAt', 'isRead']); // only mark-read is allowed
      allow create, delete: if false; // Cloud Function only
    }

    // ----------------------------------------------------------
    // follows/{followId}
    // Follow relationships (user→user, user→channel).
    // Owner can create/delete own follow records.
    // ----------------------------------------------------------
    match /follows/{followId} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.data.followerUid == request.auth.uid;
      allow delete: if isAuth()
        && resource.data.followerUid == request.auth.uid;
      allow update: if false;
    }

    // ----------------------------------------------------------
    // playlists/{playlistId}
    // User-created playlists.
    // Public playlists: any authenticated user can read.
    // Private playlists: owner only.
    // Write: owner only (non-sensitive fields).
    // ----------------------------------------------------------
    match /playlists/{playlistId} {
      allow read: if isOwner(resource.data.ownerUid)
        || (isAuth() && resource.data.get('isPublic', false) == true);
      allow create: if isAuth()
        && request.resource.data.ownerUid == request.auth.uid;
      allow update: if isOwner(resource.data.ownerUid)
        && !request.resource.data.diff(resource.data).affectedKeys()
            .hasAny(['ownerUid', 'createdAt']);
      allow delete: if isOwner(resource.data.ownerUid);
    }

    // ----------------------------------------------------------
    // points/{uid}
    // Gamification points balance per user.
    // Read: owner only.
    // Write: Cloud Function only — no client writes ever.
    //   (Prevents point manipulation attacks.)
    // ----------------------------------------------------------
    match /points/{uid} {
      allow read: if isOwner(uid);
      allow write: if false; // Cloud Function only — NEVER client-writable
    }

    // ----------------------------------------------------------
    // SERVER-ONLY COLLECTIONS
    // The following collections are completely inaccessible
    // from client SDKs. All operations go through Cloud Functions
    // using the Admin SDK which bypasses these rules entirely.
    // ----------------------------------------------------------

    // wallet/{uid} — Earnings balance and transaction ledger
    match /wallet/{uid} {
      allow read, write: if false; // Cloud Function / Admin SDK only
    }

    // paymentOrders/{orderId} — PSP payment intents and receipts
    match /paymentOrders/{orderId} {
      allow read, write: if false; // Cloud Function / Admin SDK only
    }

    // payoutRequests/{requestId} — Creator withdrawal requests
    match /payoutRequests/{requestId} {
      allow read, write: if false; // Cloud Function / Admin SDK only
    }

    // auditLog/{logId} — Platform-wide immutable audit trail
    match /auditLog/{logId} {
      allow read, write: if false; // Cloud Function / Admin SDK only
    }

    // adminConfig/{docId} — Platform global configuration
    // (feature flags, world config, package definitions, roles)
    match /adminConfig/{docId} {
      allow read, write: if false; // Cloud Function / Admin SDK only
      // Future: allow admin read via Admin SDK panel endpoint
    }

    // kycDocuments/{uid} — Identity verification documents
    // (never client-readable; only Cloud Function / Admin review)
    match /kycDocuments/{uid} {
      allow read, write: if false; // Cloud Function / Admin SDK only
    }

    // moderationQueue/{itemId} — Flagged content for moderation
    match /moderationQueue/{itemId} {
      allow read, write: if false; // Cloud Function / moderation system only
    }

    // childGuardianLinks/{linkId} — Guardian approval state
    // (no client bypass ever; guardian approval via Cloud Function)
    match /childGuardianLinks/{linkId} {
      allow read, write: if false; // Cloud Function / Admin SDK only
    }

    // radioStations/{stationId} — Platform radio station registry
    //
    // Schema fields include:
    //   ownerProfileId  — uid of the profile that created/owns the station
    //   contactConfig   — contact page fields (social links, email, etc.)
    //
    // Read: any authenticated user (station info is public).
    // Write: Cloud Function only (radio_creator capability enforced there).
    //
    // Radio comments live inside the radio player (playerComments subcollection).
    // Live broadcast messages are routed to the inbox of the ownerProfileId
    //   profile's notifications — handled by Cloud Function, not client rules.
    match /radioStations/{stationId} {
      allow read: if isAuth();
      allow write: if false; // Cloud Function only (radio_creator capability check enforced there)

      // Radio player comments subcollection
      // Comments display inside the radio player UI (not the general comment feed).
      // Read: any authenticated user.
      // Create: authenticated user (Cloud Function validates restrictions).
      // Update/Delete: Cloud Function only (moderation / owner management).
      match /playerComments/{commentId} {
        allow read: if isAuth();
        allow create: if isAuth()
          && request.resource.data.authorUid == request.auth.uid;
        allow update, delete: if false; // Cloud Function / moderation only
      }

      // Radio station contact page configuration
      // Contains: contact form config, social links, station email, etc.
      // Readable by any authenticated user (same as the station itself).
      // Writable by Cloud Function only.
      match /contactPage/{docId} {
        allow read: if isAuth();
        allow write: if false; // Cloud Function only
      }
    }

    // packages/{packageId} — Subscription package definitions
    // Read: authenticated users (needed to render pricing screens).
    // Write: Cloud Function / Admin SDK only.
    match /packages/{packageId} {
      allow read: if isAuth();
      allow write: if false; // Cloud Function / Admin SDK only
    }

    // reportReasons/{reasonId} — Report reason catalog
    // Read: authenticated users.
    // Write: Cloud Function / Admin SDK only.
    match /reportReasons/{reasonId} {
      allow read: if isAuth();
      allow write: if false; // Cloud Function / Admin SDK only
    }

    // worlds/{worldId} — World configuration definitions
    // Read: authenticated users (needed to render world tabs and navigation).
    // Write: Cloud Function / Admin SDK only.
    match /worlds/{worldId} {
      allow read: if isAuth();
      allow write: if false; // Cloud Function / Admin SDK only
    }

    // storyTypes/{typeId} — Story type catalog
    // Read: authenticated users.
    // Write: Cloud Function / Admin SDK only.
    match /storyTypes/{typeId} {
      allow read: if isAuth();
      allow write: if false; // Cloud Function / Admin SDK only
    }

    // roles/{roleId} — Role definitions
    // Read: authenticated users.
    // Write: Cloud Function / Admin SDK only.
    match /roles/{roleId} {
      allow read: if isAuth();
      allow write: if false; // Cloud Function / Admin SDK only
    }

    // permissions/{docId} — Permission matrix defaults
    // Read: authenticated users.
    // Write: Cloud Function / Admin SDK only.
    match /permissions/{docId} {
      allow read: if isAuth();
      allow write: if false; // Cloud Function / Admin SDK only
    }

    // supportCategories/{docId} — Support category catalog
    // Read: authenticated users.
    // Write: Cloud Function / Admin SDK only.
    match /supportCategories/{docId} {
      allow read: if isAuth();
      allow write: if false; // Cloud Function / Admin SDK only
    }

    // competitionDimensions/{docId} — Competition scoring dimensions
    // Read: authenticated users.
    // Write: Cloud Function / Admin SDK only.
    match /competitionDimensions/{docId} {
      allow read: if isAuth();
      allow write: if false; // Cloud Function / Admin SDK only
    }

    // childPermissionDefaults/{docId} — Default child permission config
    // Read: authenticated guardians (Cloud Function filters by role).
    // Write: Cloud Function / Admin SDK only.
    match /childPermissionDefaults/{docId} {
      allow read: if isAuth();
      allow write: if false; // Cloud Function / Admin SDK only
    }

    // featureFlags/{docId} — Feature flag defaults
    // Read: authenticated users.
    // Write: Cloud Function / Admin SDK only.
    match /featureFlags/{docId} {
      allow read: if isAuth();
      allow write: if false; // Cloud Function / Admin SDK only
    }

    // reports/{reportId} — User-submitted content/user reports
    // Create: authenticated user can submit report for own uid.
    // Read/Update/Delete: moderation system only.
    match /reports/{reportId} {
      allow create: if isAuth()
        && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if false; // moderation system only
    }

  }
}