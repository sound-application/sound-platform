# Web App Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local — it is in .gitignore.
#
# All VITE_FIREBASE_* values come from the Firebase Console:
# https://console.firebase.google.com/project/sound-platform-dev/settings/general/web
#
# Project: sound-platform-dev
# Region:  europe-west1

# ─── Firebase Web Config ─────────────────────────────────────────────────────
# These are web-safe public identifiers (not secrets).
# See: https://firebase.google.com/docs/web/setup#config-object
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ─── App Environment ─────────────────────────────────────────────────────────
# Set to "local" to connect to Firebase emulators (ports from firebase.json).
# Set to "dev" for online dev project (sound-platform-dev).
# Set to "production" for production project (do not use yet).
VITE_APP_ENV=dev

# ─── Emulator Ports (only used when VITE_APP_ENV=local) ─────────────────────
# Must match firebase.json emulator port config.
VITE_EMULATOR_AUTH_PORT=19099
VITE_EMULATOR_FIRESTORE_PORT=18080
VITE_EMULATOR_STORAGE_PORT=19199
